# ============================================
# йҢҜиӘӨй Ғйқўе°Һеҗ‘
# ============================================
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html

# Compress JSON at the web-server layer; PHP should not buffer/compress it.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ============================================
  # е®үе…ЁйҳІиӯ·пјҡе„Әе…Ҳйҳ»жӯўж•Ҹж„ҹж–Үд»¶
  # ============================================

  # йҳ»жӯў .git зӣёй—ң
  RewriteRule ^\.git - [F,L]
  RewriteRule ^\.gitignore - [F,L]

  # йҳ»жӯўж•Ҹж„ҹжӘ”жЎҲ
  RewriteRule ^(\.env|\.htaccess|\.htpasswd|composer\.(json|lock)|package\.json|package-lock\.json|vite\.config\.js)$ - [F,L]

  # йҳ»жӯўж•Ҹж„ҹзӣ®йҢ„
  RewriteRule ^(docs|frontend|node_modules|api/core)/ - [F,L]

  # йҳ»жӯў SQL е’Ң Markdown жӘ”жЎҲ
  RewriteRule \.(sql|md)$ - [F,L]

  # йҳ»жӯўзӣҙжҺҘиЁӘе•Ҹ PHP жӘ”жЎҲпјҲйҖҡйҒҺ THE_REQUEST жӘўжё¬еҺҹе§Ӣи«ӢжұӮ URLпјү
  RewriteCond %{THE_REQUEST} \.php[\s?/] [NC]
  RewriteRule \.php$ - [F,L]

  # ============================================
  # API и·Ҝз”ұ
  # ============================================

  # API ж №зӣ®еҪ•
  RewriteRule ^api/$ api/index.php [L]

  # API v0.9
  RewriteRule ^api/v0\.9/sheet$ api/v0.9/sheet.php [L]
  RewriteRule ^api/v0\.9/detail$ api/v0.9/detail.php [L]

  # API v1.0
  RewriteRule ^api/v1\.0/sheet$ api/v1.0/sheet.php [L]
  RewriteRule ^api/v1\.0/detail$ api/v1.0/detail.php [L]
  RewriteRule ^api/v1\.0/phonology$ api/v1.0/phonology.php [L]
  RewriteRule ^api/v1\.0/articles/about$ api/v1.0/articles/about.php [L]
  RewriteRule ^api/v1\.0/articles$ api/v1.0/articles/index.php [L]
  RewriteRule ^api/v1\.0/comments/char$ api/v1.0/comments/char.php [L]
  RewriteRule ^api/v1\.0/comments/counts$ api/v1.0/comments/counts.php [L]
  RewriteRule ^api/v1\.0/comments/sheet$ api/v1.0/comments/sheet.php [L]
  RewriteRule ^api/v1\.0/locations/available$ api/v1.0/locations/available.php [L]
  RewriteRule ^api/v1\.0/user/comments$ api/v1.0/user/comments.php [L]
  RewriteRule ^api/v1\.0/user/profile$ api/v1.0/user/profile.php [L]

  # API v1.0 Admin
  RewriteRule ^api/v1\.0/admin/audit$ api/v1.0/admin/audit.php [L]
  RewriteRule ^api/v1\.0/admin/common-import$ api/v1.0/admin/common-import.php [L]
  RewriteRule ^api/v1\.0/admin/common-rules$ api/v1.0/admin/common-rules.php [L]
  RewriteRule ^api/v1\.0/admin/editors$ api/v1.0/admin/editors.php [L]
  RewriteRule ^api/v1\.0/admin/location-actions$ api/v1.0/admin/location-actions.php [L]
  RewriteRule ^api/v1\.0/admin/locations$ api/v1.0/admin/locations.php [L]
  RewriteRule ^api/v1\.0/admin/maintenance$ api/v1.0/admin/maintenance.php [L]
  RewriteRule ^api/v1\.0/admin/phonology-rebuild$ api/v1.0/admin/phonology-rebuild.php [L]
  RewriteRule ^api/v1\.0/admin/users$ api/v1.0/admin/users.php [L]

  # Auth API
  RewriteRule ^api/auth/google$ api/auth/google.php [L]
  RewriteRule ^api/auth/me$ api/auth/me.php [L]
  RewriteRule ^api/auth/logout$ api/auth/logout.php [L]

  # ============================================
  # йқңж…ӢиіҮжәҗпјҡе…ҒиЁұеӯҳеңЁзҡ„жӘ”жЎҲе’Ңзӣ®йҢ„
  # ============================================
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ============================================
  # Vue Router - е…¶д»–жүҖжңүи«ӢжұӮиҪүеҗ‘ index.html
  # ============================================
  RewriteRule ^index\.html$ - [L]
  RewriteRule . /index.html [L]
</IfModule>
