<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # API / Resources bypass
  # Allow access to existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # API Specific Rules (if needed for pretty URLs, referencing old .htaccess)
  RewriteRule ^api/v0.9/sheet$ api/v0.9/sheet.php [L]
  RewriteRule ^api/v0.9/detail$ api/v0.9/detail.php [L]
  # Add v1.0 rule just in case
  RewriteRule ^api/v1.0/detail$ api/v1.0/detail.php [L]

  # Vue Router (History Mode)
  RewriteRule ^index\.html$ - [L]
  RewriteRule . /index.html [L]
</IfModule>
