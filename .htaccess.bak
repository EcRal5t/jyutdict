<Ifmodule mod_rewrite.c>
 
RewriteEngine on  //on为打开,off为关闭
RewriteRule ^pron$ pron.php
RewriteRule ^index$ index.php
RewriteRule ^sheet$ sheet.php
RewriteRule ^about$ about.php
RewriteRule ^probe$ sub/probe
RewriteRule ^404$ 404.php
#RewriteRule ^api/detail$ api/v0.9/detail.php
RewriteRule ^api/v0.9/sheet$ api/v0.9/sheet.php
RewriteRule ^api/v0.9/detail$ api/v0.9/detail.php
RewriteRule ^articles/([^.]+?)$ articles/$1.php

#RewriteCond %{SERVER_PORT} !^443$
#RewriteRule ^(.*)?$ https://%{SERVER_NAME}%{REQUEST_URI} [L,R]

ErrorDocument 404 /404
ErrorDocument 403 /404

#Order Allow,Deny
<FilesMatch "^((index|about|pron|sheet|404|)(.php)?)|(about.md)|(robots.txt)|(api/)|(articles/.*)|(sub/.*)$">
Allow from all
</FilesMatch>
Deny from all

</IfModule>
